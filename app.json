{
  "expo": {
    "name": "Grocify",
    "slug": "grocify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "grocify",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.charanjeetroshan.grocify"
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://charanjeetroshan-grocify--preview.expo.app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fff",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "backgroundColor": "#000",
            "image": "./assets/images/splash-icon-dark.png"
          }
        }
      ],
      "@clerk/expo",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/JetBrainsMono-Regular.ttf"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8861b58a-6956-4ae6-aeca-546e572d7ffa"
      }
    }
  }
}